{
  "name": "mtib-dev-blog",
  "version": "1.0.0",
  "license": "WTFPL",
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "scripts": {
    "lint": "eslint . --ext .tsx",
    "clean": "rm dist/posts/list.json dist/posts/feed.rss dist/index.html dist/*.css dist/*.js dist/*.js.map dist/*.css.map dist/dnd/* dist/*.html dist/app.manifest dist/*.png dist/sitemap.xml",
    "build:assets": "node src/scripts/generateFiles.js && node src/scripts/generateFeed.js",
    "build-dev": "yarn build:assets && NODE_ENV=development BUILD_DATE=\"$(date +%s)\" parcel build src/index.html --dist-dir dist && NODE_ENV=development yarn build-dnd-game",
    "build-dnd-game": "parcel build src/dnd/index.html --dist-dir dist/dnd --public-url /dnd/",
    "build-prod": "yarn build:assets && NODE_ENV=production BUILD_DATE=\"$(date +%s)\" parcel build src/index.html --dist-dir dist && NODE_ENV=production yarn build-dnd-game",
    "start": "yarn build:assets && parcel src/index.html",
    "start-dnd-game": "yarn build:assets && parcel src/dnd/index.html",
    "start:static": "yarn build:assets && concurrently -n parcel,serve 'yarn parcel watch src/index.html' 'yarn serve dist'",
    "static": "yarn build-prod; yarn serve dist",
    "predeploy": "yarn clean; yarn run build-prod",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@emotion/react": "^11.10.5",
    "@emotion/styled": "^11.10.5",
    "@parcel/service-worker": "^2.8.3",
    "@popperjs/core": "^2.10.1",
    "@types/marked": "^4.0.7",
    "bootstrap": "^5.2.3",
    "concurrently": "^7.6.0",
    "gh-pages": "^3.2.3",
    "highlight.js": "^11.2.0",
    "jquery": "^3.6.1",
    "marked": "^4.0.14",
    "parcel": "2.0.0-nightly.1371",
    "pixi.js": "^7.3.1",
    "popper.js": "^1.16.1",
    "react": "^18.2.0",
    "react-bootstrap": "^2.6.0",
    "react-dom": "^18.2.0",
    "serve": "^14.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.5",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.19.6",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@types/react": "^18.0.25",
    "@types/react-dom": "^18.0.9",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "babel-core": "^6.26.3",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^29.3.1",
    "babel-plugin-transform-class-properties": "^6.24.1",
    "babel-preset-env": "^1.7.0",
    "babel-preset-react": "^6.24.1",
    "eslint": "^8.28.0",
    "eslint-plugin-react": "^7.31.11",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.3.1",
    "process": "^0.11.10",
    "typescript": "^4.9.3"
  }
}
